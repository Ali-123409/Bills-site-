---
// This component automatically catches the properties passed from your city pages
const { disco, discoName, title, refnoLength = 14, hasCustomerID = true } = Astro.props;

// Ensure disco is always lowercase for the URL (e.g., 'fesco', 'gepco')
const safeDisco = (disco || 'gepco').toLowerCase();
const safeDiscoName = discoName || safeDisco.toUpperCase();
---

<bill-checker-component data-disco={safeDisco} data-length={refnoLength}>
  <div class="bill-checker bg-white p-6 rounded-2xl shadow-sm border border-neutral-100 max-w-2xl mx-auto my-6">
    
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-10 rounded-xl bg-primary-600 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </div>
      <div>
        <h2 class="text-lg font-heading font-bold text-neutral-900">{title || `${safeDiscoName} Bill Checker`}</h2>
        <p class="text-sm text-neutral-500">Enter your details to view your official bill</p>
      </div>
    </div>

    {hasCustomerID && (
      <div class="flex gap-2 mb-4">
        <button type="button" class="tab-refno px-4 py-2 rounded-lg text-sm font-medium transition-all bg-primary-600 text-white">Reference Number</button>
        <button type="button" class="tab-custid px-4 py-2 rounded-lg text-sm font-medium transition-all bg-neutral-100 text-neutral-600 hover:bg-neutral-200">Consumer ID</button>
      </div>
    )}

    <form class="billForm flex flex-col sm:flex-row gap-3" method="POST" action="" target="_blank">
      <div class="flex-1">
        <input
          type="text"
          class="bill-input w-full px-5 py-3 bg-neutral-50 border-2 border-neutral-100 rounded-xl focus:border-primary-500 outline-none font-mono text-lg"
          placeholder={`Enter ${refnoLength}-digit Reference`}
          inputmode="numeric"
          autocomplete="off"
          maxlength={refnoLength}
          required
        />
      </div>
      <button type="submit" class="bg-primary-600 hover:bg-primary-700 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-md">
        Check Bill
      </button>
    </form>

    <div class="bill-status mt-4 hidden p-4 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100 text-center"></div>

    <div class="bill-opened hidden mt-6 bg-green-50 border border-green-200 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-green-900 text-sm">Opening {safeDiscoName} Bill in a new tab...</p>
          <button type="button" class="check-again-btn text-xs text-green-800 mt-2 font-bold underline">Check Another Bill</button>
        </div>
      </div>
    </div>

  </div>
</bill-checker-component>

<script>
  class BillCheckerComponent extends HTMLElement {
    connectedCallback() {
      // Automatically pull the dynamic data attributes
      const disco = this.dataset.disco || 'gepco';
      const refnoLength = parseInt(this.dataset.length || '14', 10);
      let currentTab = 'refno';

      const form = this.querySelector('.billForm');
      const input = this.querySelector('.bill-input');
      const tabRefno = this.querySelector('.tab-refno');
      const tabCustid = this.querySelector('.tab-custid');
      const statusBox = this.querySelector('.bill-status');
      const openedBox = this.querySelector('.bill-opened');
      const checkAgainBtn = this.querySelector('.check-again-btn');

      // Handle Tab Switching
      const switchTab = (tab) => {
        currentTab = tab;
        input.placeholder = tab === 'refno' ? `Enter ${refnoLength}-digit Reference` : 'Enter 10-digit Consumer ID';
        input.maxLength = tab === 'refno' ? refnoLength : 10;
        
        if (tabRefno) tabRefno.className = `tab-refno px-4 py-2 rounded-lg text-sm font-medium ${tab === 'refno' ? 'bg-primary-600 text-white' : 'bg-neutral-100 text-neutral-600 hover:bg-neutral-200'}`;
        if (tabCustid) tabCustid.className = `tab-custid px-4 py-2 rounded-lg text-sm font-medium ${tab === 'custid' ? 'bg-primary-600 text-white' : 'bg-neutral-100 text-neutral-600 hover:bg-neutral-200'}`;
        
        input.value = '';
        statusBox.classList.add('hidden');
        openedBox.classList.add('hidden');
      };

      if (tabRefno) tabRefno.addEventListener('click', () => switchTab('refno'));
      if (tabCustid) tabCustid.addEventListener('click', () => switchTab('custid'));

      // Core Form Submission Logic (The Hybrid POST Trick)
      if (form) {
        form.addEventListener('submit', (e) => {
          const val = input.value;
          const targetLen = currentTab === 'refno' ? refnoLength : 10;
          
          // Validation Check
          if (val.length !== targetLen) {
            e.preventDefault(); 
            statusBox.innerText = `⚠️ Please enter exactly ${targetLen} digits.`;
            statusBox.classList.remove('hidden');
            return;
          }

          // Inject the specific company's URL right before the POST submits
          const param = currentTab === 'refno' ? 'refno' : 'appno';
          form.action = `https://bill.pitc.com.pk/${disco}bill/general?${param}=${val}`;

          statusBox.classList.add('hidden');
          openedBox.classList.remove('hidden');
        });
      }

      // Reset Button Logic
      if (checkAgainBtn) {
        checkAgainBtn.addEventListener('click', () => {
          openedBox.classList.add('hidden');
          input.value = '';
          form.action = '';
          input.focus();
        });
      }

      // Force input to be numbers only
      if (input) {
        input.addEventListener('input', (e) => { 
          e.target.value = e.target.value.replace(/[^0-9]/g, ''); 
          statusBox.classList.add('hidden');
        });
      }
    }
  }

  if (!customElements.get('bill-checker-component')) {
    customElements.define('bill-checker-component', BillCheckerComponent);
  }
</script>
