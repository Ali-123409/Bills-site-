---
interface Props {
  disco: string;
  discoName: string;
  refnoLength?: number;
  hasCustomerID?: boolean;
}
const { disco, discoName, refnoLength = 14, hasCustomerID = true } = Astro.props;
---

<div class="bill-checker" id="bill-checker-tool">
  <div class="flex items-center gap-3 mb-6">
    <div class="w-10 h-10 rounded-xl bg-primary-600 flex items-center justify-center flex-shrink-0">
      <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
    </div>
    <div>
      <h2 class="text-lg font-heading font-bold text-neutral-900">{discoName} Bill Checker</h2>
      <p class="text-sm text-neutral-500">Enter your details below</p>
    </div>
  </div>

  <div class="space-y-4">
    <input 
      type="text" 
      id="bill-input" 
      placeholder="Enter Reference Number" 
      class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:ring-2 focus:ring-primary-500 outline-none transition-all"
    />
    <button 
      onclick="checkBill()" 
      id="check-btn"
      class="w-full bg-primary-600 hover:bg-primary-700 text-white font-bold py-3 rounded-xl transition-colors shadow-lg shadow-primary-200"
    >
      View Bill
    </button>
  </div>

  <div id="status-container" class="mt-4 hidden p-4 rounded-xl text-sm"></div>
</div>

<script is:inline define:vars={{ disco }}>
  async function checkBill() {
    const input = document.getElementById('bill-input').value.trim();
    const status = document.getElementById('status-container');
    const btn = document.getElementById('check-btn');

    if (!input) return;

    // UI Feedback
    status.classList.remove('hidden');
    status.className = "mt-4 p-4 rounded-xl text-sm bg-blue-50 text-blue-700 border border-blue-100";
    status.innerText = "Fetching your bill...";
    btn.disabled = true;
    btn.innerText = "Loading...";

    const targetPITC = `https://bill.pitc.com.pk/${disco}bill/general?refno=${input}`;
    const proxyURL = `/api/bill?url=${encodeURIComponent(targetPITC)}`;

    try {
      const response = await fetch(proxyURL);
      if (!response.ok) throw new Error("Bill not found. Check your reference number.");

      const html = await response.text();
      
      // Open bill in new tab and inject fixed HTML
      const billWindow = window.open('', '_blank');
      if (billWindow) {
        billWindow.document.open();
        billWindow.document.write(html);
        billWindow.document.close();
        status.className = "mt-4 p-4 rounded-xl text-sm bg-green-50 text-green-700 border border-green-100";
        status.innerText = "Bill opened in new tab!";
      } else {
        throw new Error("Popup blocked! Please allow popups.");
      }
    } catch (err) {
      status.className = "mt-4 p-4 rounded-xl text-sm bg-red-50 text-red-700 border border-red-100";
      status.innerText = err.message;
    } finally {
      btn.disabled = false;
      btn.innerText = "View Bill";
    }
  }
</script>
