          <tr><td class="p-3 font-semibold">SEPCO</td><td class="p-3">Sukkur, Larkana, Khairpur (upper Sindh)</td><td class="p-3"><a href="/sepco-bill/" class="text-primary-600">/sepco-bill/</a></td></tr>
