          <tr><td class="p-3 font-semibold">MEPCO</td><td class="p-3">Multan, Bahawalpur, Dera Ghazi Khan, Sahiwal</td><td class="p-3"><a href="/mepco-bill/" class="text-primary-600">/mepco-bill/</a></td></tr>
          <tr><td class="p-3 font-semibold">PESCO</td><td class="p-3">Peshawar, Mardan, Abbottabad, KP (settled)</td><td class="p-3"><a href="/pesco-bill/" class="text-primary-600">/pesco-bill/</a></td></tr>
