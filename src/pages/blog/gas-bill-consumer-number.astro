      <div class="flex flex-wrap gap-2">
        <a href="/blog/sngpl-gas-bill-consumer-number/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">SNGPL Consumer Number Guide &rarr;</a>
