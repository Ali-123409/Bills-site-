          <tr><td class="p-3 font-semibold">ATM</td><td class="p-3">Any bank ATM in Karachi</td><td class="p-3">Free</td><td class="p-3">Instant</td></tr>
          <tr><td class="p-3 font-semibold">NADRA e-Sahulat</td><td class="p-3">Any NADRA center</td><td class="p-3">Rs. 30</td><td class="p-3">24–48h</td></tr>
        </tbody>
