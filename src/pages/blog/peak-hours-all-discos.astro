    <div class="border-t border-neutral-200 pt-6">
      <div class="flex flex-wrap gap-2">
        <a href="/blog/electricity-tariff-2026/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">Electricity Tariff 2026 Guide &rarr;</a>
        <a href="/blog/electricity-saving-tips-pakistan/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">Electricity Saving Tips &rarr;</a>
        <a href="/blog/solar-net-metering-pakistan-2026/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">Solar Net-Metering &rarr;</a>
