---
const disco = "gepco";
const discoName = "GEPCO";
const refnoLength = 14;
const hasCustomerID = true;
---

<bill-checker-component data-disco={disco} data-length={refnoLength}>
  <div class="bill-checker bg-white p-6 rounded-2xl shadow-sm border border-neutral-100">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-10 rounded-xl bg-primary-600 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
      <div>
        <h2 class="text-lg font-heading font-bold text-neutral-900">{discoName} Bill Checker</h2>
        <p class="text-sm text-neutral-500">Enter your 14-digit reference number</p>
      </div>
    </div>

    {hasCustomerID && (
      <div class="flex gap-2 mb-4">
        <button class="tab-refno px-4 py-2 rounded-lg text-sm font-medium transition-all bg-primary-600 text-white">Reference Number</button>
        <button class="tab-custid px-4 py-2 rounded-lg text-sm font-medium transition-all bg-neutral-100 text-neutral-600">Consumer ID</button>
      </div>
    )}

    <div class="flex flex-col sm:flex-row gap-3">
      <div class="flex-1">
        <input
          type="text"
          class="bill-input w-full px-5 py-3 bg-neutral-50 border-2 border-neutral-100 rounded-xl focus:border-primary-500 outline-none font-mono text-lg"
          placeholder={`14-digit Reference Number`}
          inputmode="numeric"
        />
      </div>
      <button class="check-btn bg-primary-600 hover:bg-primary-700 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-md">
        Check Bill
      </button>
    </div>

    <div class="bill-status mt-4 hidden p-4 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100"></div>

    <div class="bill-opened hidden mt-6 bg-green-50 border border-green-200 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-green-900 text-sm">Opening {discoName} Bill...</p>
          <p class="text-green-700 text-xs mt-1">If the bill didn't open, your browser might be blocking pop-ups.</p>
          <button class="check-again-btn text-xs text-primary-700 mt-2 font-bold underline">Check Another Bill</button>
        </div>
      </div>
    </div>
  </div>
</bill-checker-component>

<script>
  class BillCheckerComponent extends HTMLElement {
    connectedCallback() {
      const disco = this.dataset.disco || 'gepco';
      const refnoLength = parseInt(this.dataset.length || '14', 10);
      let currentTab = 'refno';

      const input = this.querySelector('.bill-input');
      const tabRefno = this.querySelector('.tab-refno');
      const tabCustid = this.querySelector('.tab-custid');
      const checkBtn = this.querySelector('.check-btn');
      const statusBox = this.querySelector('.bill-status');
      const openedBox = this.querySelector('.bill-opened');
      const checkAgainBtn = this.querySelector('.check-again-btn');

      const switchTab = (tab) => {
        currentTab = tab;
        input.placeholder = tab === 'refno' ? `${refnoLength}-digit Reference Number` : '10-digit Consumer ID';
        tabRefno.className = `tab-refno px-4 py-2 rounded-lg text-sm font-medium ${tab === 'refno' ? 'bg-primary-600 text-white' : 'bg-neutral-100 text-neutral-600'}`;
        tabCustid.className = `tab-custid px-4 py-2 rounded-lg text-sm font-medium ${tab === 'custid' ? 'bg-primary-600 text-white' : 'bg-neutral-100 text-neutral-600'}`;
        input.value = '';
        statusBox.classList.add('hidden');
      };

      if (tabRefno) tabRefno.addEventListener('click', () => switchTab('refno'));
      if (tabCustid) tabCustid.addEventListener('click', () => switchTab('custid'));

      const doCheckBill = () => {
        const val = input.value.replace(/\s/g, '');
        const targetLen = currentTab === 'refno' ? refnoLength : 10;
        
        if (val.length !== targetLen) {
          statusBox.innerText = `⚠️ Please enter exactly ${targetLen} digits.`;
          statusBox.classList.remove('hidden');
          return;
        }

        // --- THE STEALTH FIX ---
        const param = currentTab === 'refno' ? 'refno' : 'appno';
        
        // We use the direct .aspx endpoint which is more reliable than /general
        const finalURL = `https://bill.pitc.com.pk/${disco}bill.aspx?${param}=${val}`;

        // Create a temporary "Stealth Link"
        const link = document.createElement('a');
        link.href = finalURL;
        link.target = '_blank';
        link.rel = 'noreferrer'; // CRITICAL: This hides your website from PITC
        
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);

        openedBox.classList.remove('hidden');
        statusBox.classList.add('hidden');
      };

      checkBtn.addEventListener('click', doCheckBill);
      checkAgainBtn.addEventListener('click', () => {
        openedBox.classList.add('hidden');
        input.value = '';
        input.focus();
      });

      input.addEventListener('keydown', (e) => { if (e.key === 'Enter') doCheckBill(); });
      // Force numbers only
      input.addEventListener('input', (e) => { e.target.value = e.target.value.replace(/[^0-9]/g, ''); });
    }
  }
  customElements.define('bill-checker-component', BillCheckerComponent);
</script>
